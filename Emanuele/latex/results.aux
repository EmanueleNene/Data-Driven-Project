\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \texttt  {01\_training\_inputs\_rich\_signal.png} -- The 5-sine training excitation ($\varepsilon $, blue; $\dot  {\varepsilon }$, green). This replaces the original narrow 2-sine signal; the wider amplitude and added frequency content is what breaks the $\dot  {\varepsilon }/\dot  {\varepsilon }^3$ collinearity discussed above.}}{6}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2}3D Deviatoric Validation Figures (\texttt  {ViscoElasticity\_tensor\_3D/NonLinear\_3D/fit\_nonlinear\_deviatoric\_sindy.py})}{6}{}\protected@file@percent }
