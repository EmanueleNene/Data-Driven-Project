\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \texttt  {02\_training\_outputs\_reconstruction.png} -- SINDy's reconstructed stress (red dashed) against the noisy training data (black dots) and the noise-free true signal (black line), over the training window.}}{7}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \texttt  {03\_training\_stress\_strain.png} -- Same training reconstruction, viewed as a stress-strain hysteresis loop rather than a time series.}}{7}{}\protected@file@percent }
